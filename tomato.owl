<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato/"
     xml:base="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:tomato="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato">
        <rdfs:comment xml:lang="en-ie">This is an ontology about Tomatoes. This ontology is the second assignment for Human Centered System module.</rdfs:comment>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#gownUnder -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#gownUnder">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#GrowingCondition"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#hasVariety -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#hasVariety">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#usesTomato -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#usesTomato">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Dish"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#climate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#climate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#GrowingCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#colour -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#colour">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#cookingMethod -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#cookingMethod">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Dish"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#cuisine -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#cuisine">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Dish"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#dishName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#dishName">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Dish"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#flavor -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#flavor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#harvestDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#harvestDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#isOrganic -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#isOrganic">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#pH -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#pH">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#season -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#season">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#GrowingCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#size -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#size">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#soilType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#soilType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#GrowingCondition"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#tomatoID -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#tomatoID">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#usesTomato -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#usesTomato">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#varietyName -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#varietyName">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
