        <rdf:type rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
        <tomato:gownUnder rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Greenhouse_Condition"/>
        <tomato:colour>Red</tomato:colour>
        <tomato:flavor>Sweet and acidy</tomato:flavor>
        <tomato:size>Medium</tomato:size>
        <tomato:varietyName>Alicante</tomato:varietyName>
    </owl:NamedIndividual>
    


