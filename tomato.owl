    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#weight -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#weight">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Dish -->

    <owl:Class rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Dish">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#usesTomato"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Food -->

    <owl:Class rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Food"/>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Fruit -->

    <owl:Class rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Fruit">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Food"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#GrowingCondition -->

    <owl:Class rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#GrowingCondition">
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato -->

    <owl:Class rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Tomato">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#Fruit"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety -->

    <owl:Class rdf:about="http://www.semanticweb.org/tmolnar/ontologies/2026/3/tomato#TomatoVariety"/>
    


